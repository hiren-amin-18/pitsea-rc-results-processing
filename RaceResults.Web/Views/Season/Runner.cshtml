@model RaceResults.Web.Models.RunnerSeasonProfile
@using RaceResults.Web.Models
@{
    ViewData["Title"] = "Runner Season";
    string TypeLabel(EventType t) => t == EventType.CrownToCrown ? "Crown to Crown" : "Bluebell 5";
}

<h1>@Model.Runner.Name</h1>
<p class="text-muted">
    @(string.IsNullOrWhiteSpace(Model.Runner.Club) ? "Unaffiliated" : Model.Runner.Club) - @Model.Year season
    <a asp-action="Dashboard" asp-route-year="@Model.Year" class="ms-2">← Season dashboard</a>
</p>

<div class="row g-3 mb-2">
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Races completed</h6><p class="display-6 mb-0">@Model.Races.Count<span class="fs-6 text-muted"> / @Model.EventsHeld held</span></p></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Avg position</h6><p class="display-6 mb-0">@(Model.AverageFinishPosition?.ToString() ?? "-")</p></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Avg in category</h6><p class="display-6 mb-0">@(Model.AverageCategoryPosition?.ToString() ?? "-")</p></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Current streak</h6><p class="display-6 mb-0">@Model.CurrentStreak</p></div></div></div>
</div>

@if (Model.ExcludedTimeRows > 0)
{
    <p class="small text-warning">@Model.ExcludedTimeRows of this runner's races had an unparseable time and are excluded from time bests.</p>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card h-100"><div class="card-body">
            <h5 class="card-title">Races</h5>
            @if (Model.Races.Any())
            {
                <table class="table table-sm mb-0">
                    <thead><tr><th>Event</th><th>Date</th><th>Type</th><th>Pos</th><th>Category</th><th>Time</th></tr></thead>
                    <tbody>
                    @foreach (var r in Model.Races)
                    {
                        <tr><td>@r.EventName</td><td>@r.EventDate.ToString("dd MMM")</td><td>@TypeLabel(r.EventType)</td><td>@r.Position</td><td>@r.Category</td><td>@(r.Time ?? "-")</td></tr>
                    }
                    </tbody>
                </table>
            }
            else { <p class="text-muted mb-0">No finishes recorded this season.</p> }
        </div></div>
    </div>
    <div class="col-lg-5">
        <div class="card mb-3"><div class="card-body">
            <h5 class="card-title">Season best (per event type)</h5>
            @if (Model.SeasonBests.Any())
            {
                <ul class="list-unstyled mb-0">
                @foreach (var b in Model.SeasonBests)
                {
                    <li><strong>@TypeLabel(b.EventType):</strong> @b.Time <span class="text-muted">(@b.EventName)</span></li>
                }
                </ul>
            }
            else { <p class="text-muted mb-0">No timed finishes.</p> }
        </div></div>
        <div class="card"><div class="card-body">
            <h5 class="card-title">Champions points progression</h5>
            @if (Model.ChampionsProgression.Any())
            {
                <table class="table table-sm mb-0">
                    <thead><tr><th>Event</th><th>Points</th><th>Cumulative</th></tr></thead>
                    <tbody>
                    @foreach (var p in Model.ChampionsProgression)
                    {
                        <tr><td>@p.EventName</td><td>@p.PointsThisEvent</td><td>@p.CumulativePoints</td></tr>
                    }
                    </tbody>
                </table>
            }
            else { <p class="text-muted mb-0">No Crown to Crown (May–September) races this season.</p> }
        </div></div>
    </div>
</div>
