@model RaceResults.Web.Models.ResultsPageViewModel
@{
    ViewData["Title"] = "Results";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Collated Results</h1>
    <div class="btn-group">
        <a class="btn btn-outline-primary" asp-action="ExportPdf">Export PDF</a>
        <a class="btn btn-outline-primary" asp-action="ExportCsv">Export CSV</a>
    </div>
</div>

@if (TempData["FeedbackText"] is string feedback)
{
    var feedbackType = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@feedbackType" role="alert">@Html.Raw(feedback)</div>
}

@if (!Model.Results.Any())
{
    <div class="alert alert-info">No collated results yet. Upload files first.</div>
}
else
{
    var unmatchedCount = Model.Results.Count(r => r.IsUnmatched);
    if (unmatchedCount > 0)
    {
        <div class="alert alert-warning" role="alert">
            @unmatchedCount finish @(unmatchedCount == 1 ? "position has" : "positions have") a bib number with no registered entrant. Review the highlighted rows and correct them via Edit.
        </div>
    }
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th class="text-center">Pos</th>
                    <th class="text-center">Time</th>
                    <th class="text-center">Bib</th>
                    <th>Name</th>
                    <th>Club</th>
                    <th class="text-center">Gender</th>
                    <th>Age</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Results)
            {
                <tr class="@(row.IsUnmatched ? "table-warning" : null)">
                    <td class="text-center">@row.Position</td>
                    <td class="text-center">@row.Time</td>
                    <td class="text-center">@row.BibNumber</td>
                    <td>
                        @row.Name
                        @if (row.IsUnmatched)
                        {
                            <span class="badge bg-warning text-dark ms-1">Unmatched</span>
                        }
                    </td>
                    <td>@row.Club</td>
                    <td class="text-center">@row.Gender</td>
                    <td>@(row.Age?.ToString() ?? "-")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="EditResult" asp-route-position="@row.Position">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<h2 class="mt-4">DNF</h2>
@if (!Model.DnfEntrants.Any())
{
    <p>None</p>
}
else
{
    <ul>
    @foreach (var dnf in Model.DnfEntrants)
    {
        var clubSuffix = string.IsNullOrWhiteSpace(dnf.Club) ? string.Empty : $" ({dnf.Club})";
        <li>@dnf.BibNumber - @dnf.Name@clubSuffix</li>
    }
    </ul>
}
