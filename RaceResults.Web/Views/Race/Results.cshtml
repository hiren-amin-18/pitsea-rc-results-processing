@model RaceResults.Web.Models.ResultsPageViewModel
@using RaceResults.Web.Services
@{
    ViewData["Title"] = "Results";
    // Winner = earliest finishing position that has a typed time (gap-to-winner).
    var winnerDuration = Model.Results.FirstOrDefault(r => r.Duration.HasValue)?.Duration;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Collated Results</h1>
    <div class="btn-group">
        <a class="btn btn-outline-primary" asp-action="ExportPdf" asp-route-eventId="@Model.ViewedEventId">Export PDF</a>
        <a class="btn btn-outline-primary" asp-action="ExportCsv" asp-route-eventId="@Model.ViewedEventId">Export CSV</a>
    </div>
</div>

@if (Model.IsReadOnly)
{
    <div class="alert alert-secondary" role="alert">
        Viewing <strong>@Model.ViewedEventName</strong>@(Model.IsArchived ? " (archived)" : " (not the current event)") - read-only.
    </div>
}

@if (TempData["FeedbackText"] is string feedback)
{
    var feedbackType = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@feedbackType" role="alert">@Html.Raw(feedback)</div>
}

@if (Model.PendingCourseRecords.Any())
{
    <div class="alert alert-success" role="alert">
        <h5 class="alert-heading">🏆 Potential new course record@(Model.PendingCourseRecords.Count == 1 ? "" : "s")!</h5>
        <p class="mb-2">Confirm to update the stored record (it keeps a history of previous holders). Decline if this looks like a timing error or short course.</p>
        @foreach (var pending in Model.PendingCourseRecords)
        {
            <div class="d-flex align-items-center gap-2 mb-1">
                <span>
                    <strong>@pending.Category:</strong> @pending.Time - @pending.RunnerName
                    @if (string.IsNullOrEmpty(pending.PreviousTime))
                    {
                        <span class="text-muted">(first record for this category)</span>
                    }
                    else
                    {
                        <span class="text-muted">(beats @pending.PreviousTime)</span>
                    }
                </span>
                <form method="post" asp-action="ConfirmCourseRecord" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="category" value="@pending.Category" />
                    <button type="submit" class="btn btn-sm btn-success">Confirm record</button>
                </form>
            </div>
        }
    </div>
}

@if (!Model.Results.Any())
{
    <div class="alert alert-info">No collated results yet. Upload files first.</div>
}
else
{
    var unmatchedCount = Model.Results.Count(r => r.IsUnmatched);
    if (unmatchedCount > 0)
    {
        <div class="alert alert-warning" role="alert">
            @unmatchedCount finish @(unmatchedCount == 1 ? "position has" : "positions have") a bib number with no registered entrant. Review the highlighted rows and correct them via Edit.
        </div>
    }
    <div class="table-responsive" style="overflow-x: clip;">
        <table class="table table-striped align-middle">
            <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
                <tr>
                    <th class="text-center">Pos</th>
                    <th class="text-center">Time</th>
                    <th class="text-center">Gap</th>
                    <th class="text-center">Bib</th>
                    <th>Name</th>
                    <th>Club</th>
                    <th class="text-center">Gender</th>
                    <th>Age</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Results)
            {
                <tr class="@(row.IsUnmatched ? "table-warning" : null)">
                    <td class="text-center">@row.DisplayPosition</td>
                    <td class="text-center">@row.Time</td>
                    <td class="text-center">@(row.Duration.HasValue && winnerDuration.HasValue ? RaceTime.FormatGap(row.Duration.Value - winnerDuration.Value) : "")</td>
                    <td class="text-center">@row.BibNumber</td>
                    <td>
                        @row.Name
                        @if (row.IsUnmatched)
                        {
                            <span class="badge bg-warning text-dark ms-1">Unmatched</span>
                        }
                    </td>
                    <td>@row.Club</td>
                    <td class="text-center">@row.Gender</td>
                    <td>@(row.Age?.ToString() ?? "-")</td>
                    <td class="text-nowrap">
                        @if (!Model.IsReadOnly)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="EditResult" asp-route-position="@row.Position">Edit</a>
                            @if (!row.IsUnmatched)
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Disqualify" asp-route-position="@row.Position">DSQ</a>
                            }
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (Model.DsqResults.Any())
{
    <h2 class="mt-4">Disqualified (DSQ)</h2>
    <p class="small text-muted">Removed from the results above; positions close up automatically.</p>
    <ul class="list-unstyled">
    @foreach (var dsq in Model.DsqResults)
    {
        var clubSuffix = string.IsNullOrWhiteSpace(dsq.Club) ? string.Empty : $" ({dsq.Club})";
        <li class="mb-2">
            <strong>@dsq.BibNumber - @dsq.Name</strong>@clubSuffix
            @if (!string.IsNullOrWhiteSpace(dsq.StatusReason))
            {
                <span class="text-muted">- @dsq.StatusReason</span>
            }
            @if (!Model.IsReadOnly)
            {
                <form method="post" asp-action="Reinstate" asp-route-position="@dsq.Position" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-success" type="submit">Reinstate</button>
                </form>
            }
        </li>
    }
    </ul>
}

<h2 class="mt-4">DNF</h2>
@if (!Model.DnfEntrants.Any())
{
    <p>None</p>
}
else
{
    <ul class="list-unstyled">
    @foreach (var dnf in Model.DnfEntrants)
    {
        var clubSuffix = string.IsNullOrWhiteSpace(dnf.Club) ? string.Empty : $" ({dnf.Club})";
        <li class="mb-1">
            @dnf.BibNumber - @dnf.Name@clubSuffix
            @if (!Model.IsReadOnly)
            {
                <form method="post" asp-action="SetStatus" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bibNumber" value="@dnf.BibNumber" />
                    <input type="hidden" name="status" value="@RaceResults.Web.Models.FinishStatus.DidNotStart" />
                    <button class="btn btn-sm btn-outline-secondary" type="submit" title="They never started">Mark DNS</button>
                </form>
            }
        </li>
    }
    </ul>
}

<h2 class="mt-4">DNS</h2>
<p class="small text-muted">Registered but never started - excluded from results, statistics, and the PDF.</p>
@if (!Model.DnsEntrants.Any())
{
    <p>None</p>
}
else
{
    <ul class="list-unstyled">
    @foreach (var dns in Model.DnsEntrants)
    {
        var clubSuffix = string.IsNullOrWhiteSpace(dns.Club) ? string.Empty : $" ({dns.Club})";
        <li class="mb-1">
            @dns.BibNumber - @dns.Name@clubSuffix
            @if (!Model.IsReadOnly)
            {
                <form method="post" asp-action="SetStatus" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bibNumber" value="@dns.BibNumber" />
                    <input type="hidden" name="status" value="@RaceResults.Web.Models.FinishStatus.DidNotFinish" />
                    <button class="btn btn-sm btn-outline-secondary" type="submit" title="Move back to DNF">Mark DNF</button>
                </form>
            }
        </li>
    }
    </ul>
}
