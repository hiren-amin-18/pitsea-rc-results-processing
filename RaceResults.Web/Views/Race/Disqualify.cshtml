@model RaceResults.Web.Models.DisqualifyInput
@{
    ViewData["Title"] = "Disqualify Finisher";
}

<h1>Disqualify Finisher</h1>
<p class="text-muted">Disqualifying removes this finisher from the results (positions below close up) and voids any Champions of Champions points for this event. It can be reversed from the Results page.</p>

@if (TempData["FeedbackText"] is string feedback)
{
    var feedbackType = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@feedbackType" role="alert">@Html.Raw(feedback)</div>
}

<form method="post" asp-action="Disqualify" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="Position" type="hidden" />

    <div class="col-md-8">
        <label asp-for="Reason" class="form-label">Reason (required)</label>
        <input asp-for="Reason" class="form-control" placeholder="e.g. Course cut, unregistered runner" />
        <span asp-validation-for="Reason" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button class="btn btn-danger" type="submit">Disqualify</button>
        <a class="btn btn-outline-secondary" asp-action="Results">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
