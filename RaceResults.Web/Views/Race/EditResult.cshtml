@model RaceResults.Web.Models.EditResultInput
@{
    ViewData["Title"] = "Edit Result";
}

<h1>Edit Result Row</h1>
<p class="text-muted">Update a result row without re-uploading all files.</p>

@if (TempData["FeedbackText"] is string feedback)
{
    var feedbackType = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@feedbackType" role="alert">@Html.Raw(feedback)</div>
}

<form method="post" asp-action="EditResult" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="OriginalPosition" type="hidden" />

    <div class="col-md-4">
        <label asp-for="NewPosition" class="form-label"></label>
        <input asp-for="NewPosition" class="form-control" />
        <span asp-validation-for="NewPosition" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="BibNumber" class="form-label"></label>
        <input asp-for="BibNumber" class="form-control" />
        <span asp-validation-for="BibNumber" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Club" class="form-label"></label>
        <input asp-for="Club" class="form-control" />
        <span asp-validation-for="Club" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Gender" class="form-label"></label>
        <input asp-for="Gender" class="form-control" />
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Age" class="form-label"></label>
        <input asp-for="Age" class="form-control" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Time" class="form-label"></label>
        <input asp-for="Time" class="form-control" placeholder="25:10" />
        <div class="form-text">Format: <code>mm:ss</code> or <code>h:mm:ss</code> (e.g. <code>25:10</code> or <code>1:05:09</code>). Leave blank for no time.</div>
        <span asp-validation-for="Time" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Save Changes</button>
        <a class="btn btn-outline-secondary" asp-action="Results">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
