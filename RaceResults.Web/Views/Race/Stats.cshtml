@using System.Text.Json
@using RaceResults.Web.Services
@model RaceResults.Web.Models.RaceStatsDashboardViewModel
@{
    ViewData["Title"] = "Race Stats";
    var clubChartHeight = Math.Max(320, Model.ClubBreakdown.Count * 30);
    var summary = Model.Summary;
    string Fmt(TimeSpan? t) => t.HasValue ? RaceTime.Format(t.Value) : "-";
}

<h1>Race Statistics</h1>

<div class="row g-3 mt-1">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Completion</h5>
                <p class="display-6 mb-1">@summary.CompletionRatePercent%</p>
                <p class="mb-0 text-muted">@summary.FinisherCount of @summary.EntrantCount starters finished</p>
                <p class="mb-0 small text-muted">DNF: @summary.DnfCount &middot; DNS: @summary.DnsCount</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Gender split (finishers)</h5>
                <p class="mb-1">Male: <strong>@summary.MaleFinishers</strong> (@summary.MalePercent%)</p>
                <p class="mb-0">Female: <strong>@summary.FemaleFinishers</strong> (@summary.FemalePercent%)</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Finish times</h5>
                @if (summary.HasTimes)
                {
                    <p class="mb-1">Winner: <strong>@Fmt(summary.WinnerTime)</strong> &middot; Median: <strong>@Fmt(summary.MedianTime)</strong> &middot; Average: <strong>@Fmt(summary.AverageTime)</strong></p>
                    <p class="mb-1 small text-muted">Winner→median spread: @Fmt(summary.WinnerToMedianSpread)</p>
                    <p class="mb-0 small text-muted">Cut-offs - top 25%: @Fmt(summary.Percentile25) &middot; 50%: @Fmt(summary.Percentile50) &middot; 75%: @Fmt(summary.Percentile75)</p>
                }
                else
                {
                    <p class="mb-0 text-muted">No finish times yet.</p>
                }
                @if (summary.ExcludedTimeRowCount > 0)
                {
                    <p class="mb-0 small text-warning">@summary.ExcludedTimeRowCount finisher(s) excluded from time stats (unparseable time).</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Males</h5><p class="display-6">@Model.Stats.TotalMales</p></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Females</h5><p class="display-6">@Model.Stats.TotalFemales</p></div></div></div>
    @if (Model.IsBluebell)
    {
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Vet Males (40+)</h5><p class="display-6">@Model.Stats.TotalMalesVet</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Vet Females (35+)</h5><p class="display-6">@Model.Stats.TotalFemalesVet</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Senior Males (U40)</h5><p class="display-6">@Model.Stats.TotalMalesNonVet</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Senior Females (U35)</h5><p class="display-6">@Model.Stats.TotalFemalesNonVet</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Males Unaffiliated</h5><p class="display-6">@Model.Stats.TotalMalesUnaffiliatedExcludingU18</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Females Unaffiliated</h5><p class="display-6">@Model.Stats.TotalFemalesUnaffiliatedExcludingU18</p></div></div></div>
    }
    else
    {
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Males (U18)</h5><p class="display-6">@Model.Stats.TotalMalesU18</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Females (U18)</h5><p class="display-6">@Model.Stats.TotalFemalesU18</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Males Unaffiliated (Excl U18)</h5><p class="display-6">@Model.Stats.TotalMalesUnaffiliatedExcludingU18</p></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><h5>Females Unaffiliated (Excl U18)</h5><p class="display-6">@Model.Stats.TotalFemalesUnaffiliatedExcludingU18</p></div></div></div>
    }
</div>

<div class="row g-3 mt-2">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="chart-card-head">
                    <h5 class="card-title mb-0">Male / Female</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary chart-expand" data-chart="gender" title="Expand chart" aria-label="Expand Male / Female chart">⤢ Expand</button>
                </div>
                <div style="height: 340px;"><canvas id="genderChart" aria-label="Male female breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="chart-card-head">
                    <h5 class="card-title mb-0">Category Breakdown</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary chart-expand" data-chart="category" title="Expand chart" aria-label="Expand Category Breakdown chart">⤢ Expand</button>
                </div>
                <div style="height: 340px;"><canvas id="categoryChart" aria-label="Category breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="chart-card-head">
                    <h5 class="card-title mb-0">Affiliated vs Unaffiliated</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary chart-expand" data-chart="affiliation" title="Expand chart" aria-label="Expand Affiliated vs Unaffiliated chart">⤢ Expand</button>
                </div>
                <div style="height: 340px;"><canvas id="affiliationChart" aria-label="Affiliated vs unaffiliated breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="chart-card-head">
                    <h5 class="card-title mb-0">Club Breakdown</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary chart-expand" data-chart="club" title="Expand chart" aria-label="Expand Club Breakdown chart">⤢ Expand</button>
                </div>
                <div style="height: @(clubChartHeight)px;"><canvas id="clubChart" aria-label="Club breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="chart-card-head">
                    <h5 class="card-title mb-0">Time Per Minute vs Finishers</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary chart-expand" data-chart="minute" title="Expand chart" aria-label="Expand Finishers per minute chart">⤢ Expand</button>
                </div>
                @if (summary.BusiestWindowMinute.HasValue)
                {
                    <p class="small text-muted mb-2">Peak: @summary.BusiestWindowCount finishers between @($"{summary.BusiestWindowMinute:00}:00") and @($"{summary.BusiestWindowMinute + 1:00}:00")</p>
                }
                <div style="height: 360px;"><canvas id="minuteChart" aria-label="Finishers per minute"></canvas></div>
            </div>
        </div>
    </div>
</div>

<p class="mt-3 text-muted">Unaffiliated means runners without a club.</p>

<div class="modal fade" id="chartModal" tabindex="-1" aria-labelledby="chartModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="chartModalTitle">Chart</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div style="height: 72vh;"><canvas id="chartModalCanvas" aria-label="Expanded chart"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/lib/chartjs-plugin-datalabels/chartjs-plugin-datalabels.min.js"></script>
    <script>
        (() => {
            if (!window.Chart) {
                return;
            }

            // Value/percentage labels drawn on the charts.
            if (window.ChartDataLabels) {
                Chart.register(window.ChartDataLabels);
            }

            // --- Data (from the server) ---
            const genderValues = [@Model.Stats.TotalMales, @Model.Stats.TotalFemales];
            const isBluebell = @(Model.IsBluebell ? "true" : "false");
            const categoryLabels = isBluebell
                ? ["Male (Senior)", "Female (Senior)", "Male (Vet)", "Female (Vet)"]
                : ["Male", "Female", "Male (U18)", "Female (U18)"];
            const categoryValues = isBluebell
                ? [@Model.Stats.TotalMalesNonVet, @Model.Stats.TotalFemalesNonVet, @Model.Stats.TotalMalesVet, @Model.Stats.TotalFemalesVet]
                : [@Model.Stats.TotalMales, @Model.Stats.TotalFemales, @Model.Stats.TotalMalesU18, @Model.Stats.TotalFemalesU18];
            const affiliationValues = [@Model.Summary.AffiliatedCount, @Model.Summary.UnaffiliatedCount];

            const clubLabels = @Html.Raw(JsonSerializer.Serialize(Model.ClubBreakdown.Select(x => x.Label)));
            const clubValues = @Html.Raw(JsonSerializer.Serialize(Model.ClubBreakdown.Select(x => x.Value)));

            const minuteLabels = @Html.Raw(JsonSerializer.Serialize(Model.FinishersPerMinute.Select(x => x.Label)));
            const minuteValues = @Html.Raw(JsonSerializer.Serialize(Model.FinishersPerMinute.Select(x => x.Value)));

            const paletteLight = ["#0066ff", "#ff6a00", "#00c2ff", "#ff2ea6", "#7a33ff", "#24cc6b", "#ffbf00", "#ff3b30", "#00b894", "#6c5ce7"];
            const paletteDark  = ["#4da3ff", "#ff9f43", "#45d6ff", "#ff66c4", "#b084ff", "#42e88f", "#ffd166", "#ff6b6b", "#33d9b2", "#a29bfe"];

            // Theme snapshot, re-read whenever the chart is (re)built.
            function theme() {
                const isDark = document.documentElement.getAttribute("data-theme") === "dark";
                return {
                    isDark,
                    text: isDark ? "#eef4ff" : "#18212f",
                    grid: isDark ? "#2f4359" : "#dbe2ec",
                    palette: isDark ? paletteDark : paletteLight
                };
            }

            const pctLabels = (t) => ({
                color: "#ffffff",
                font: { weight: "700", size: 13 },
                textAlign: "center",
                formatter: (value, ctx) => {
                    const arr = ctx.chart.data.datasets[0].data;
                    const total = arr.reduce((a, b) => a + (Number(b) || 0), 0);
                    if (!total || !value) return "";
                    return value + "\n" + Math.round((value / total) * 100) + "%";
                }
            });

            const valueLabels = (t) => ({
                anchor: "end",
                align: "end",
                clamp: true,
                color: t.text,
                font: { weight: "600" },
                formatter: (v) => (v > 0 ? v : "")
            });

            // Each definition builds a *fresh* Chart.js config for the given theme,
            // so the inline chart and the expanded (modal) chart never share state.
            const DEFS = [
                {
                    key: "gender", title: "Male / Female",
                    build: (t) => ({
                        type: "doughnut",
                        data: { labels: ["Male", "Female"], datasets: [{ data: genderValues, backgroundColor: [t.palette[0], t.palette[1]] }] },
                        options: {
                            maintainAspectRatio: false,
                            plugins: { legend: { position: "bottom", labels: { color: t.text, padding: 14 } }, datalabels: pctLabels(t) }
                        }
                    })
                },
                {
                    key: "category", title: "Category Breakdown",
                    build: (t) => ({
                        type: "bar",
                        data: { labels: categoryLabels, datasets: [{ label: "Count", data: categoryValues, backgroundColor: [t.palette[0], t.palette[1], t.palette[2], t.palette[3]] }] },
                        options: {
                            maintainAspectRatio: false,
                            scales: {
                                x: { ticks: { color: t.text }, grid: { color: t.grid } },
                                y: { beginAtZero: true, ticks: { color: t.text, precision: 0 }, grid: { color: t.grid } }
                            },
                            plugins: { legend: { display: false }, datalabels: valueLabels(t) }
                        }
                    })
                },
                {
                    key: "affiliation", title: "Affiliated vs Unaffiliated",
                    build: (t) => ({
                        type: "doughnut",
                        data: { labels: ["Affiliated", "Unaffiliated"], datasets: [{ data: affiliationValues, backgroundColor: [t.palette[5], t.palette[6]] }] },
                        options: {
                            maintainAspectRatio: false,
                            plugins: { legend: { position: "bottom", labels: { color: t.text, padding: 14 } }, datalabels: pctLabels(t) }
                        }
                    })
                },
                {
                    key: "club", title: "Club Breakdown",
                    build: (t) => ({
                        type: "bar",
                        data: { labels: clubLabels, datasets: [{ label: "Finishers", data: clubValues, backgroundColor: clubLabels.map((_, i) => t.palette[i % t.palette.length]) }] },
                        options: {
                            maintainAspectRatio: false,
                            indexAxis: "y",
                            scales: {
                                x: { beginAtZero: true, ticks: { color: t.text, precision: 0 }, grid: { color: t.grid } },
                                y: { ticks: { color: t.text, autoSkip: false, font: { size: 11 } }, grid: { color: t.grid } }
                            },
                            plugins: { legend: { display: false }, datalabels: valueLabels(t) }
                        }
                    })
                },
                {
                    key: "minute", title: "Time Per Minute vs Finishers",
                    build: (t) => ({
                        type: "line",
                        data: { labels: minuteLabels, datasets: [{ label: "Finishers", data: minuteValues, borderColor: t.palette[4], backgroundColor: t.isDark ? "rgba(176,132,255,0.28)" : "rgba(122,51,255,0.20)", fill: true, tension: 0.25, pointRadius: 2, pointHoverRadius: 5 }] },
                        options: {
                            maintainAspectRatio: false,
                            scales: {
                                x: { title: { display: true, text: "Minute", color: t.text }, ticks: { color: t.text }, grid: { color: t.grid } },
                                y: { beginAtZero: true, title: { display: true, text: "Finishers", color: t.text }, ticks: { color: t.text, precision: 0 }, grid: { color: t.grid } }
                            },
                            plugins: { legend: { labels: { color: t.text } }, datalabels: { display: false } }
                        }
                    })
                }
            ];

            // --- Inline charts ---
            const inline = {};
            function renderInline() {
                const t = theme();
                DEFS.forEach((d) => {
                    const el = document.getElementById(d.key + "Chart");
                    if (!el) return;
                    if (inline[d.key]) inline[d.key].destroy();
                    inline[d.key] = new Chart(el, d.build(t));
                });
            }
            renderInline();

            // --- Expand-to-modal ---
            let modalChart = null;
            let modalKey = null;
            const modalEl = document.getElementById("chartModal");
            const modal = modalEl && window.bootstrap ? new bootstrap.Modal(modalEl) : null;

            function renderModal() {
                const d = DEFS.find((x) => x.key === modalKey);
                if (!d) return;
                if (modalChart) modalChart.destroy();
                document.getElementById("chartModalTitle").textContent = d.title;
                modalChart = new Chart(document.getElementById("chartModalCanvas"), d.build(theme()));
            }

            if (modal) {
                document.querySelectorAll(".chart-expand").forEach((btn) => {
                    btn.addEventListener("click", () => { modalKey = btn.dataset.chart; modal.show(); });
                });
                // Render only once the canvas has real dimensions.
                modalEl.addEventListener("shown.bs.modal", renderModal);
                modalEl.addEventListener("hidden.bs.modal", () => {
                    if (modalChart) { modalChart.destroy(); modalChart = null; }
                    modalKey = null;
                });
            }

            // --- React to the dark-mode toggle without a page reload ---
            new MutationObserver((muts) => {
                if (muts.some((m) => m.attributeName === "data-theme")) {
                    renderInline();
                    if (modalChart) renderModal();
                }
            }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
        })();
    </script>
}
