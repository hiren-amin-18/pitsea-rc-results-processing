@using System.Text.Json
@using RaceResults.Web.Services
@model RaceResults.Web.Models.RaceStatsDashboardViewModel
@{
    ViewData["Title"] = "Race Stats";
    var clubChartHeight = Math.Max(320, Model.ClubBreakdown.Count * 30);
    var summary = Model.Summary;
    string Fmt(TimeSpan? t) => t.HasValue ? RaceTime.Format(t.Value) : "-";
}

<h1>Race Statistics</h1>

<div class="row g-3 mt-1">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Completion</h5>
                <p class="display-6 mb-1">@summary.CompletionRatePercent%</p>
                <p class="mb-0 text-muted">@summary.FinisherCount of @summary.EntrantCount starters finished</p>
                <p class="mb-0 small text-muted">DNF: @summary.DnfCount &middot; DNS: @summary.DnsCount</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Gender split (finishers)</h5>
                <p class="mb-1">Male: <strong>@summary.MaleFinishers</strong> (@summary.MalePercent%)</p>
                <p class="mb-0">Female: <strong>@summary.FemaleFinishers</strong> (@summary.FemalePercent%)</p>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Finish times</h5>
                @if (summary.HasTimes)
                {
                    <p class="mb-1">Winner: <strong>@Fmt(summary.WinnerTime)</strong> &middot; Median: <strong>@Fmt(summary.MedianTime)</strong> &middot; Average: <strong>@Fmt(summary.AverageTime)</strong></p>
                    <p class="mb-1 small text-muted">Winner→median spread: @Fmt(summary.WinnerToMedianSpread)</p>
                    <p class="mb-0 small text-muted">Cut-offs - top 25%: @Fmt(summary.Percentile25) &middot; 50%: @Fmt(summary.Percentile50) &middot; 75%: @Fmt(summary.Percentile75)</p>
                }
                else
                {
                    <p class="mb-0 text-muted">No finish times yet.</p>
                }
                @if (summary.ExcludedTimeRowCount > 0)
                {
                    <p class="mb-0 small text-warning">@summary.ExcludedTimeRowCount finisher(s) excluded from time stats (unparseable time).</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Males</h5><p class="display-6">@Model.Stats.TotalMales</p></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Females</h5><p class="display-6">@Model.Stats.TotalFemales</p></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Males (U18)</h5><p class="display-6">@Model.Stats.TotalMalesU18</p></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Total Females (U18)</h5><p class="display-6">@Model.Stats.TotalFemalesU18</p></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Males Unaffiliated (Excl U18)</h5><p class="display-6">@Model.Stats.TotalMalesUnaffiliatedExcludingU18</p></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><h5>Females Unaffiliated (Excl U18)</h5><p class="display-6">@Model.Stats.TotalFemalesUnaffiliatedExcludingU18</p></div></div></div>
</div>

<div class="row g-3 mt-2">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Male / Female</h5>
                <div style="height: 280px;"><canvas id="genderChart" aria-label="Male female breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Category Breakdown</h5>
                <div style="height: 280px;"><canvas id="categoryChart" aria-label="Category breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Affiliated vs Unaffiliated</h5>
                <div style="height: 280px;"><canvas id="affiliationChart" aria-label="Affiliated vs unaffiliated breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Club Breakdown</h5>
                <div style="height: @(clubChartHeight)px;"><canvas id="clubChart" aria-label="Club breakdown"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Time Per Minute vs Finishers</h5>
                @if (summary.BusiestWindowMinute.HasValue)
                {
                    <p class="small text-muted mb-2">Peak: @summary.BusiestWindowCount finishers between @($"{summary.BusiestWindowMinute:00}:00") and @($"{summary.BusiestWindowMinute + 1:00}:00")</p>
                }
                <div style="height: 320px;"><canvas id="minuteChart" aria-label="Finishers per minute"></canvas></div>
            </div>
        </div>
    </div>
</div>

<p class="mt-3 text-muted">Unaffiliated means runners without a club.</p>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (() => {
            if (!window.Chart) {
                return;
            }

            const isDark = document.documentElement.getAttribute("data-theme") === "dark";
            const textColor = isDark ? "#eef4ff" : "#18212f";
            const gridColor = isDark ? "#2f4359" : "#dbe2ec";

            const genderValues = [@Model.Stats.TotalMales, @Model.Stats.TotalFemales];
            const categoryValues = [@Model.Stats.TotalMales, @Model.Stats.TotalFemales, @Model.Stats.TotalMalesU18, @Model.Stats.TotalFemalesU18];
            const affiliationValues = [@Model.Summary.AffiliatedCount, @Model.Summary.UnaffiliatedCount];

            const clubLabels = @Html.Raw(JsonSerializer.Serialize(Model.ClubBreakdown.Select(x => x.Label)));
            const clubValues = @Html.Raw(JsonSerializer.Serialize(Model.ClubBreakdown.Select(x => x.Value)));

            const minuteLabels = @Html.Raw(JsonSerializer.Serialize(Model.FinishersPerMinute.Select(x => x.Label)));
            const minuteValues = @Html.Raw(JsonSerializer.Serialize(Model.FinishersPerMinute.Select(x => x.Value)));

            const vividPaletteLight = ["#0066ff", "#ff6a00", "#00c2ff", "#ff2ea6", "#7a33ff", "#24cc6b", "#ffbf00", "#ff3b30", "#00b894", "#6c5ce7"];
            const vividPaletteDark = ["#4da3ff", "#ff9f43", "#45d6ff", "#ff66c4", "#b084ff", "#42e88f", "#ffd166", "#ff6b6b", "#33d9b2", "#a29bfe"];
            const activePalette = isDark ? vividPaletteDark : vividPaletteLight;
            const clubBarColors = clubLabels.map((_, index) => activePalette[index % activePalette.length]);

            new Chart(document.getElementById("genderChart"), {
                type: "doughnut",
                data: {
                    labels: ["Male", "Female"],
                    datasets: [{
                        data: genderValues,
                        backgroundColor: [activePalette[0], activePalette[1]]
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: { color: textColor }
                        }
                    }
                }
            });

            new Chart(document.getElementById("affiliationChart"), {
                type: "doughnut",
                data: {
                    labels: ["Affiliated", "Unaffiliated"],
                    datasets: [{
                        data: affiliationValues,
                        backgroundColor: [activePalette[5], activePalette[6]]
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: { color: textColor }
                        }
                    }
                }
            });

            new Chart(document.getElementById("categoryChart"), {
                type: "bar",
                data: {
                    labels: ["Male", "Female", "Male (U18)", "Female (U18)"],
                    datasets: [{
                        label: "Count",
                        data: categoryValues,
                        backgroundColor: [activePalette[0], activePalette[1], activePalette[2], activePalette[3]]
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        x: { ticks: { color: textColor }, grid: { color: gridColor } },
                        y: { beginAtZero: true, ticks: { color: textColor }, grid: { color: gridColor } }
                    },
                    plugins: { legend: { display: false } }
                }
            });

            new Chart(document.getElementById("clubChart"), {
                type: "bar",
                data: {
                    labels: clubLabels,
                    datasets: [{
                        label: "Finishers",
                        data: clubValues,
                        backgroundColor: clubBarColors
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    indexAxis: "y",
                    scales: {
                        x: { beginAtZero: true, ticks: { color: textColor, precision: 0 }, grid: { color: gridColor } },
                        y: { ticks: { color: textColor, autoSkip: false, font: { size: 11 } }, grid: { color: gridColor } }
                    },
                    plugins: { legend: { display: false } }
                }
            });

            new Chart(document.getElementById("minuteChart"), {
                type: "line",
                data: {
                    labels: minuteLabels,
                    datasets: [{
                        label: "Finishers",
                        data: minuteValues,
                        borderColor: activePalette[4],
                        backgroundColor: isDark ? "rgba(176,132,255,0.28)" : "rgba(122,51,255,0.20)",
                        fill: true,
                        tension: 0.25
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        x: { title: { display: true, text: "Minute", color: textColor }, ticks: { color: textColor }, grid: { color: gridColor } },
                        y: { beginAtZero: true, title: { display: true, text: "Finishers", color: textColor }, ticks: { color: textColor }, grid: { color: gridColor } }
                    },
                    plugins: {
                        legend: { labels: { color: textColor } }
                    }
                }
            });
        })();
    </script>
}
