@model RaceResults.Web.Models.EditCourseRecordInput
@using RaceResults.Web.Models
@{
    ViewData["Title"] = "Edit Course Record";
    var typeLabel = Model.EventType == EventType.CrownToCrown ? "Crown to Crown" : "Bluebell 5";
}

<h1>Course Record</h1>
<p class="text-muted">@typeLabel - @Model.Category</p>


<form method="post" asp-action="Edit" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="EventType" type="hidden" />
    <input asp-for="Category" type="hidden" />

    <div class="col-md-4">
        <label asp-for="Time" class="form-label">Time</label>
        <input asp-for="Time" class="form-control" placeholder="15:25" />
        <div class="form-text">Format: <code>mm:ss</code> or <code>h:mm:ss</code>.</div>
        <span asp-validation-for="Time" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="RunnerName" class="form-label">Runner</label>
        <input asp-for="RunnerName" class="form-control" />
        <span asp-validation-for="RunnerName" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Club" class="form-label">Club</label>
        <input asp-for="Club" class="form-control" />
        <span asp-validation-for="Club" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="EventName" class="form-label">Event name</label>
        <input asp-for="EventName" class="form-control" placeholder="Crown to Crown" />
        <span asp-validation-for="EventName" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="EventDate" class="form-label">Date set</label>
        <input asp-for="EventDate" class="form-control" type="date" />
        <span asp-validation-for="EventDate" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Save Record</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
