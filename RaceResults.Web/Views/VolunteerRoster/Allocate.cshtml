@model RaceResults.Web.Models.AllocationFormInput
@{
    var grid = ViewBag.Grid as IReadOnlyList<RaceResults.Web.Models.AllocationGridRow>
        ?? new List<RaceResults.Web.Models.AllocationGridRow>();
    var roles = ViewBag.Roles as IReadOnlyList<RaceResults.Web.Models.VolunteerRole>
        ?? new List<RaceResults.Web.Models.VolunteerRole>();
    var raceEvent = (RaceResults.Web.Models.RaceEvent)ViewBag.Event;
    var isBluebell = raceEvent.EventType == RaceResults.Web.Models.EventType.Bluebell5;
    ViewData["Title"] = $"Allocate Roster - {raceEvent.EventName}";
    var anySaved = grid.Any(g => g.IsSelected);
}

<h1>Allocate Draft Roster</h1>
<p class="text-muted">@raceEvent.EventName - @raceEvent.EventDate.ToString("dd MMM yyyy")</p>
<p class="small text-muted">
    Tick the volunteers attending this event and any preferences. Rows start from each volunteer's usual
    preferences@(anySaved ? " — this grid was restored from your last visit" : ""). The allocator drafts a
    roster honouring the priority rules from US32; you then review and apply.
</p>

<form method="post" asp-action="Allocate" asp-route-eventId="@Model.EventId">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="EventId" />

    <div class="d-flex gap-2 mb-2">
        <button type="button" class="btn btn-link btn-sm p-0" onclick="document.querySelectorAll('input.candidate-tick').forEach(c => c.checked = true);">Select all</button>
        <span class="text-muted">·</span>
        <button type="button" class="btn btn-link btn-sm p-0" onclick="document.querySelectorAll('input.candidate-tick').forEach(c => c.checked = false);">Clear all</button>
    </div>

    <div class="table-responsive" style="overflow-x: clip;">
        <table class="table table-sm align-middle">
            <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
                <tr>
                    <th style="width: 30px;" class="text-center">✓</th>
                    <th>Name</th>
                    @if (isBluebell)
                    {
                        <th class="small text-muted text-nowrap text-center">Any role</th>
                        <th class="small text-muted text-nowrap text-center">Run after</th>
                        <th class="small text-muted text-nowrap text-center">Start/Finish</th>
                        <th class="small text-muted text-nowrap text-center">Race HQ</th>
                    }
                    else
                    {
                        <th>Preferred role</th>
                        <th class="small text-muted text-nowrap text-center">Any role</th>
                        <th class="small text-muted text-nowrap text-center">Run after</th>
                        <th class="small text-muted text-nowrap text-center">Near finish</th>
                        <th class="small text-muted text-nowrap text-center">Can't walk far</th>
                        <th class="small text-muted text-nowrap text-center">Seated</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < grid.Count; i++)
                {
                    var row = grid[i];
                    var v = row.Volunteer;
                    var c = row.Candidate;
                    <tr>
                        <td>
                            <input type="checkbox" name="Candidates[@i].VolunteerId" value="@v.Id" class="candidate-tick" checked="@row.IsSelected" />
                        </td>
                        <td>
                            @v.Name
                            @if (v.IsFirstAidTrained) { <span class="badge bg-danger ms-1">FA</span> }
                            @if (!v.IsClubMember) { <span class="badge bg-secondary ms-1">Non-member</span> }
                        </td>
                        @if (isBluebell)
                        {
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].AnyRole" value="true" checked="@c.AnyRole" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].WantsToRunAfter" value="true" checked="@c.WantsToRunAfter" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].WantsNearFinish" value="true" checked="@c.WantsNearFinish" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].WantsRaceHq" value="true" checked="@c.WantsRaceHq" /></td>
                        }
                        else
                        {
                            <td>
                                <select name="Candidates[@i].PreferredRoleId" class="form-select form-select-sm">
                                    <option value="">-</option>
                                    @foreach (var r in roles)
                                    {
                                        <option value="@r.Id" selected="@(c.PreferredRoleId == r.Id)">@r.Name</option>
                                    }
                                </select>
                            </td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].AnyRole" value="true" checked="@c.AnyRole" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].WantsToRunAfter" value="true" checked="@c.WantsToRunAfter" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].WantsNearFinish" value="true" checked="@c.WantsNearFinish" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].CantWalkFar" value="true" checked="@c.CantWalkFar" /></td>
                            <td class="text-center"><input type="checkbox" name="Candidates[@i].WantsSeated" value="true" checked="@c.WantsSeated" /></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="submit" class="btn btn-primary">Generate draft</button>
    <a class="btn btn-link" asp-action="Index" asp-route-eventId="@Model.EventId">Cancel</a>
</form>
