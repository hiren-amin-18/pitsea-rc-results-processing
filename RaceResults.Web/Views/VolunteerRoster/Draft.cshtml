@model RaceResults.Web.Models.AllocationDraft
@{
    ViewData["Title"] = $"Draft Roster - {Model.EventName}";
    var draftJson = System.Text.Json.JsonSerializer.Serialize(Model);
}

<h1>Draft Roster</h1>
<p class="text-muted">@Model.EventName - @Model.EventDate.ToString("dd MMM yyyy")</p>
<p class="small text-muted">Review the proposed allocation. Click Apply to add these assignments to the roster (existing assignments are kept; nothing is deleted). After applying you can adjust the roster freely.</p>

<form method="post" asp-action="Apply" asp-route-eventId="@Model.EventId" id="apply-form"
      onsubmit="return confirm('Apply ' + document.querySelectorAll('.proposal-tick:checked').length + ' proposed assignment(s) to the roster? Existing assignments are kept; this only adds.');">
    @Html.AntiForgeryToken()
    <input type="hidden" name="draftJson" value="@draftJson" />
    <div class="mb-3">
        <button type="submit" class="btn btn-primary" id="apply-btn" @(Model.Proposals.Count == 0 ? "disabled" : "")>Apply draft (@Model.Proposals.Count)</button>
        <a class="btn btn-link" asp-action="Allocate" asp-route-eventId="@Model.EventId">Back</a>
    </div>

@if (Model.Proposals.Count == 0)
{
    <div class="alert alert-info">The allocator produced no proposals. Either no candidates were selected on the previous page, or every selected candidate was rejected by a hard constraint (see the report below).</div>
}

<h3>Proposed assignments (@Model.Proposals.Count)</h3>
<p class="small text-muted">Untick any proposal you disagree with before applying — only ticked rows are added to the roster.</p>
<div class="table-responsive" style="overflow-x: clip;">
    <table class="table table-sm align-middle">
        <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);"><tr><th style="width: 30px;" class="text-center">✓</th><th>Volunteer</th><th>Role</th><th>Category</th><th>Run after?</th><th>Reason</th></tr></thead>
        <tbody>
        @foreach (var (p, originalIndex) in Model.Proposals
            .Select((p, i) => (p, i))
            .OrderBy(x => x.p.Category).ThenBy(x => x.p.RoleName).ThenBy(x => x.p.VolunteerName))
        {
            var reasonLabel = p.Reason switch {
                RaceResults.Web.Models.AllocationReason.PrePlaced        => "Pre-placed",
                RaceResults.Web.Models.AllocationReason.Eligibility      => "Eligibility",
                RaceResults.Web.Models.AllocationReason.RunAfterRotation => "Run-after rotation",
                RaceResults.Web.Models.AllocationReason.Preference       => "Preference",
                RaceResults.Web.Models.AllocationReason.Mix              => "Mix",
                RaceResults.Web.Models.AllocationReason.Fill             => "Fill",
                RaceResults.Web.Models.AllocationReason.FinishLine       => "Finish line (also OTD/NC)",
                _ => p.Reason.ToString()
            };
            var isFinishLine = p.Reason == RaceResults.Web.Models.AllocationReason.FinishLine;
            <tr class="@(isFinishLine ? "table-info" : null)">
                <td class="text-center"><input type="checkbox" class="proposal-tick" name="includeIndexes" value="@originalIndex" checked /></td>
                <td>@p.VolunteerName</td>
                <td>@p.RoleName</td>
                <td>@p.Category</td>
                <td>@(p.WillRunAfter ? "Yes" : "")</td>
                <td><span class="badge @(isFinishLine ? "bg-info text-dark" : "bg-light text-dark border")">@reasonLabel</span></td>
            </tr>
        }
        </tbody>
    </table>
</div>
</form>

<script>
    document.querySelectorAll('.proposal-tick').forEach(t => t.addEventListener('change', () => {
        const n = document.querySelectorAll('.proposal-tick:checked').length;
        const btn = document.getElementById('apply-btn');
        btn.textContent = `Apply draft (${n})`;
        btn.disabled = n === 0;
    }));
</script>

@if (Model.Report.UnfilledRoles.Any())
{
    <h3 class="mt-3">Unfilled roles</h3>
    <ul class="small">
        @foreach (var u in Model.Report.UnfilledRoles)
        {
            <li>@u.RoleName: @u.Assigned/@u.Default (min @u.Min)</li>
        }
    </ul>
}

@if (Model.Report.UnplacedCandidates.Any())
{
    <h3 class="mt-3">Unplaced candidates</h3>
    <ul class="small text-danger">
        @foreach (var u in Model.Report.UnplacedCandidates)
        {
            <li>@u.Name - @u.Reason</li>
        }
    </ul>
}

@if (Model.Report.PreferencesNotHonoured.Any())
{
    <h3 class="mt-3">Preferences not honoured</h3>
    <ul class="small text-warning-emphasis">
        @foreach (var p in Model.Report.PreferencesNotHonoured)
        {
            <li>@p</li>
        }
    </ul>
}

@if (Model.Report.Notes.Any())
{
    <ul class="small text-muted">
        @foreach (var n in Model.Report.Notes) { <li>@n</li> }
    </ul>
}
