@model RaceResults.Web.Models.ChampionsLeaderboardViewModel

@{
    ViewData["Title"] = "Champions of Champions Leaderboard";
}

<h1>Champions of Champions Leaderboard</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h5 class="card-title mb-2">@Model.SeasonYear Season</h5>
                <p class="text-muted mb-0">As of: <strong>@Model.AsOfDate.ToString("MMMM d, yyyy")</strong> - Event: <strong>@Model.CurrentEventName</strong></p>
            </div>
            <div class="col-md-4 text-end">
                <form asp-action="CalculatePoints" asp-controller="Champions" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="eventId" value="@Model.CurrentEventId" />
                    <button type="submit" class="btn btn-primary btn-sm me-2">Calculate Points</button>
                </form>
                <label for="yearSelector" class="form-label small">View Season:</label>
                <select id="yearSelector" class="form-select form-select-sm" style="display: inline-block; width: auto;">
                    @for (int y = DateTime.Now.Year; y >= 2024; y--)
                    {
                            <option value="@y" selected="@(y == Model.SeasonYear)">@y</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('yearSelector').addEventListener('change', function(e) {
        const year = e.target.value;
        const url = new URL(window.location);
        url.searchParams.set('year', year);
        window.location = url.toString();
    });
</script>

<!-- Summary / Details toggle (US44) -->
<div class="btn-group mb-3" role="group" aria-label="Leaderboard view">
    <a class="btn btn-sm @(Model.ShowDetail ? "btn-outline-primary" : "btn-primary")"
       href="@Url.Action("Leaderboard", new { eventId = Model.CurrentEventId, year = Model.SeasonYear })">Summary</a>
    <a class="btn btn-sm @(Model.ShowDetail ? "btn-primary" : "btn-outline-primary")"
       href="@Url.Action("Leaderboard", new { eventId = Model.CurrentEventId, year = Model.SeasonYear, detail = true })">Show details</a>
</div>

<!-- Tie-Breaking Key -->
<div class="alert alert-info mb-4">
    <strong>ℹ️ How Ties Are Broken:</strong> When runners have equal points, they are ranked by number of races completed (more events = higher rank).
    <strong style="color: #ff6b6b;">†</strong> indicates runners with tied points.
</div>

@if (!Model.Leaderboard.Any())
{
    <div class="alert alert-info">No Champions of Champions data available yet. Results will appear after the first Crown to Crown race is scored.</div>
}
else if (Model.ShowDetail && Model.Detail != null)
{
    var columns = Model.Detail.Columns;
    var rowsByCategory = Model.Detail.Rows.GroupBy(r => r.Entry.Category).ToList();

    @foreach (var category in rowsByCategory)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@category.Key</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
                            <tr>
                                <th style="width: 70px;">Rank</th>
                                <th>Name</th>
                                <th>Club</th>
                                @foreach (var column in columns)
                                {
                                    <th class="text-center" title="@column.EventName (@column.EventDate.ToString("MMMM d, yyyy"))">@column.Label</th>
                                }
                                <th class="text-center">Events</th>
                                <th class="text-end">Points</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in category.OrderBy(r => r.Entry.Rank))
                            {
                                var entry = row.Entry;
                                var highlightClass = entry.HighlightClass ?? string.Empty;
                                <tr class="@highlightClass">
                                    <td>
                                        <strong>@entry.Rank</strong>@if (entry.IsPointsTied) { <span style="color: #ff6b6b; font-weight: bold; margin-left: 4px;">†</span> }
                                    </td>
                                    <td><strong>@entry.Entrant.Name</strong></td>
                                    <td>@(string.IsNullOrEmpty(entry.Entrant.Club) ? "Unaffiliated" : entry.Entrant.Club)</td>
                                    @foreach (var column in columns)
                                    {
                                        var points = row.PointsFor(column.EventId);
                                        <td class="text-center">@(points?.ToString() ?? "–")</td>
                                    }
                                    <td class="text-center"><strong>@entry.RaceCount</strong></td>
                                    <td class="text-end fw-bold">@entry.TotalPoints</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
else
{
    var categories = Model.Leaderboard.GroupBy(e => e.Category).ToList();

    @foreach (var category in categories)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@category.Key</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive" style="overflow-x: clip;">
                    <table class="table table-striped table-hover mb-0">
                        <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
                            <tr>
                                <th style="width: 80px;">Rank</th>
                                <th>Name</th>
                                <th>Club</th>
                                <th style="width: 100px; text-align: center;">Events</th>
                                <th style="width: 100px; text-align: right;">Points</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in category.OrderBy(e => e.Rank))
                            {
                                var highlightClass = entry.HighlightClass ?? string.Empty;
                                <tr class="@highlightClass">
                                    <td>
                                        <span class="badge bg-primary" style="font-size: 1rem; padding: 0.5rem 0.75rem;">
                                            @entry.Rank
                                            @if (entry.IsPointsTied)
                                            {
                                                <span style="color: #ff6b6b; font-weight: bold; margin-left: 4px;">†</span>
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@entry.Entrant.Name</strong>
                                        @if (entry.Entrant.Age.HasValue)
                                        {
                                            <span class="small text-muted">(Age @entry.Entrant.Age)</span>
                                        }
                                    </td>
                                    <td>@(string.IsNullOrEmpty(entry.Entrant.Club) ? "Unaffiliated" : entry.Entrant.Club)</td>
                                    <td style="text-align: center;">
                                        <strong>@entry.RaceCount</strong>
                                    </td>
                                    <td style="text-align: right; font-weight: bold;">
                                        <span style="font-size: 1.1rem;">@entry.TotalPoints</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

<div class="mt-4">
    <a href="@Url.Action("ExportPdf", new { eventId = Model.CurrentEventId, year = Model.SeasonYear, detail = Model.ShowDetail })" class="btn btn-primary">
        <i class="bi bi-file-pdf"></i> Export to PDF@(Model.ShowDetail ? " (detailed)" : "")
    </a>
    <a href="@Url.Action("ExportCsv", new { eventId = Model.CurrentEventId, year = Model.SeasonYear, detail = Model.ShowDetail })" class="btn btn-outline-primary">
        <i class="bi bi-filetype-csv"></i> Export to CSV@(Model.ShowDetail ? " (detailed)" : "")
    </a>
</div>

<style>
    .rank-gold td {
        background-color: #fff8e1 !important;
        color: #000;
    }

    .rank-gold td:first-child {
        border-left: 4px solid #d4af37;
    }

    .rank-silver td {
        background-color: #f4f4f4 !important;
        color: #000;
    }

    .rank-silver td:first-child {
        border-left: 4px solid #9e9e9e;
    }

    .rank-bronze td {
        background-color: #fbf0e6 !important;
        color: #000;
    }

    .rank-bronze td:first-child {
        border-left: 4px solid #cd7f32;
    }
</style>
