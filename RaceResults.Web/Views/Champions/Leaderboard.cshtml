@model RaceResults.Web.Models.ChampionsLeaderboardViewModel

@{
    ViewData["Title"] = "Champions of Champions Leaderboard";
}

<h1>Champions of Champions Leaderboard</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h5 class="card-title mb-2">@Model.SeasonYear Season</h5>
                <p class="text-muted mb-0">As of: <strong>@Model.AsOfDate.ToString("MMMM d, yyyy")</strong> — Event: <strong>@Model.CurrentEventName</strong></p>
            </div>
            <div class="col-md-4 text-end">
                <label for="yearSelector" class="form-label small">View Season:</label>
                <select id="yearSelector" class="form-select form-select-sm" style="display: inline-block; width: auto;">
                    @for (int y = DateTime.Now.Year; y >= 2024; y--)
                    {
                        <option value="@y" @(y == Model.SeasonYear ? "selected" : "")>@y</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('yearSelector').addEventListener('change', function(e) {
        const year = e.target.value;
        const url = new URL(window.location);
        url.searchParams.set('year', year);
        window.location = url.toString();
    });
</script>

<!-- Tie-Breaking Key -->
<div class="alert alert-info mb-4">
    <strong>ℹ️ How Ties Are Broken:</strong> When runners have equal points, they are ranked by number of races completed (more events = higher rank). 
    <strong style="color: #ff6b6b;">†</strong> indicates runners with tied points.
</div>

@if (!Model.Leaderboard.Any())
{
    <div class="alert alert-info">No Champions of Champions data available yet. Results will appear after the first Crown to Crown race is scored.</div>
}
else
{
    var categories = Model.Leaderboard.GroupBy(e => e.Category).ToList();

    @foreach (var category in categories)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@category.Key</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Rank</th>
                                <th>Name</th>
                                <th>Club</th>
                                <th style="width: 100px; text-align: center;">Events</th>
                                <th style="width: 100px; text-align: right;">Points</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in category.OrderBy(e => e.Rank))
                            {
                                var highlightClass = entry.HighlightClass ?? string.Empty;
                                <tr class="@highlightClass">
                                    <td>
                                        <span class="badge bg-primary" style="font-size: 1rem; padding: 0.5rem 0.75rem;">
                                            @entry.Rank
                                            @if (entry.IsPointsTied)
                                            {
                                                <span style="color: #ff6b6b; font-weight: bold; margin-left: 4px;">†</span>
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@entry.Entrant.Name</strong>
                                        @if (entry.Entrant.Age.HasValue)
                                        {
                                            <span class="small text-muted">(Age @entry.Entrant.Age)</span>
                                        }
                                    </td>
                                    <td>@(string.IsNullOrEmpty(entry.Entrant.Club) ? "Unaffiliated" : entry.Entrant.Club)</td>
                                    <td style="text-align: center;">
                                        <strong>@entry.RaceCount</strong>
                                    </td>
                                    <td style="text-align: right; font-weight: bold;">
                                        <span style="font-size: 1.1rem;">@entry.TotalPoints</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

<div class="mt-4">
    <a href="@Url.Action("ExportPdf", new { eventId = Model.CurrentEventId, year = Model.SeasonYear })" class="btn btn-primary">
        <i class="bi bi-file-pdf"></i> Export to PDF
    </a>
</div>

<style>
    .rank-gold {
        background-color: #ffd700 !important;
        color: #000;
    }

    .rank-gold td {
        background-color: #ffd700;
    }

    .rank-silver {
        background-color: #c0c0c0 !important;
        color: #000;
    }

    .rank-silver td {
        background-color: #c0c0c0;
    }

    .rank-bronze {
        background-color: #cd7f32 !important;
        color: #fff;
    }

    .rank-bronze td {
        background-color: #cd7f32;
    }
</style>
