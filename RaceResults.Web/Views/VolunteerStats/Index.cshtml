@model RaceResults.Web.Models.SeasonVolunteerStats
@{
    ViewData["Title"] = $"Volunteer Stats - {Model.Year}";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1>Volunteer Stats</h1>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" asp-action="Index" class="d-flex gap-2 align-items-center">
            <label class="small text-muted">Year:</label>
            <select name="year" class="form-select form-select-sm" onchange="this.form.submit()">
                @foreach (var y in Model.AvailableYears.Distinct().OrderByDescending(x => x))
                {
                    var selected = y == Model.Year ? "selected" : null;
                    <option value="@y" selected="@selected">@y</option>
                }
            </select>
        </form>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Csv" asp-route-year="@Model.Year">Export CSV</a>
    </div>
</div>

<p class="small text-muted">Volunteer recognition across all event types for @Model.Year. London Marathon ballot entries count one per event volunteered at (not per assignment) - <strong>members only</strong>.</p>

@if (Model.TotalInstances == 0)
{
    <div class="alert alert-info">
        No volunteer assignments recorded for @Model.Year yet.
        Add volunteers to the <a asp-controller="Volunteers" asp-action="Index">register</a>, then build a roster for an event from the <a asp-controller="Events" asp-action="Index">Events</a> page.
        Stats appear here as soon as the first assignment is added.
    </div>
    return;
}

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Total instances</div><div class="fs-3">@Model.TotalInstances</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Unique volunteers</div><div class="fs-3">@Model.UniqueVolunteers</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Ballot entries (members)</div><div class="fs-3">@Model.TotalBallotEntries</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Events covered</div><div class="fs-3">@Model.EventsCovered</div></div></div></div>
</div>

<h3>Most active</h3>
@if (Model.MostActive.Any())
{
    <table class="table table-sm align-middle">
        <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);"><tr><th>#</th><th>Name</th><th class="text-center">Events</th><th class="text-center">Assignments</th><th class="text-center">Ballot</th><th></th></tr></thead>
        <tbody>
        @for (var i = 0; i < Model.MostActive.Count; i++)
        {
            var p = Model.MostActive[i];
            <tr>
                <td>@(i + 1)</td>
                <td>@p.Name @if (!p.IsClubMember) { <span class="badge bg-secondary ms-1">Non-member</span> }</td>
                <td class="text-center">@p.EventsAttended</td>
                <td class="text-center">@p.Assignments</td>
                <td class="text-center">@p.BallotEntries</td>
                <td>@if (p.IsEverPresent) { <span class="badge bg-success">Ever-present</span> }</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p class="text-muted small">No volunteer assignments recorded for @Model.Year yet.</p>
}

<h3 class="mt-4">All volunteers (sorted by ballot entries)</h3>
@if (Model.VolunteerProfiles.Any())
{
    <div class="table-responsive" style="overflow-x: clip;">
        <table class="table table-sm table-striped align-middle">
            <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
                <tr>
                    <th>Name</th>
                    <th>Member</th>
                    <th class="text-center">Events</th>
                    <th class="text-center">Assignments</th>
                    <th class="text-center">Ballot</th>
                    <th class="text-center">Run-after</th>
                    <th>Roles</th>
                    <th>Ran &amp; volunteered</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.VolunteerProfiles)
            {
                <tr>
                    <td>@p.Name @if (p.IsEverPresent) { <span class="badge bg-success ms-1">Ever-present</span> }</td>
                    <td>@(p.IsClubMember ? "Yes" : "No")</td>
                    <td class="text-center">@p.EventsAttended</td>
                    <td class="text-center">@p.Assignments</td>
                    <td class="text-center">@p.BallotEntries</td>
                    <td class="text-center">@p.RunAfterCount</td>
                    <td class="small">@string.Join(", ", p.RolesPerformed.Select(r => $"{r.RoleName} ×{r.Times}"))</td>
                    <td class="small">
                        @if (p.RunAndVolunteer != null)
                        {
                            <text>ran @p.RunAndVolunteer.RunCount, volunteered @p.RunAndVolunteer.VolunteerCount, in @p.RunAndVolunteer.EventsInvolvedIn event(s)</text>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<h3 class="mt-4">Role coverage trend</h3>
@if (Model.RoleCoverageTrend.Any())
{
    <table class="table table-sm align-middle" style="max-width: 720px;">
        <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);"><tr><th>Event</th><th>Date</th><th class="text-center">Assignments</th><th class="text-center">Volunteers</th></tr></thead>
        <tbody>
        @foreach (var t in Model.RoleCoverageTrend)
        {
            <tr>
                <td>@t.EventName</td>
                <td>@t.EventDate.ToString("dd MMM yyyy")</td>
                <td class="text-center">@t.TotalAssignments</td>
                <td class="text-center">@t.DistinctVolunteers</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p class="text-muted small">No events in @Model.Year.</p>
}
