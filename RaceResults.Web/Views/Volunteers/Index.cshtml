@model IReadOnlyList<RaceResults.Web.Models.VolunteerListItem>
@{
    ViewData["Title"] = "Volunteers";
    var showInactive = ViewBag.ShowInactive == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Volunteers</h1>
    <a class="btn btn-primary" asp-action="Create">Add Volunteer</a>
</div>

<p class="small text-muted">The volunteer register. Deactivate, never delete — past assignments stay counted in stats. London Marathon ballot entries (US29) count only for club members.</p>

@if (TempData["FeedbackText"] is string feedback)
{
    var ftype = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@ftype" role="alert">@Html.Raw(feedback)</div>
}

<div class="mb-2">
    <a class="small" asp-action="Index" asp-route-showInactive="@(!showInactive)">@(showInactive ? "Hide inactive" : "Show inactive")</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No volunteers yet. Add the first one to start building a roster.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Gender</th>
                    <th>Member</th>
                    <th>First Aid</th>
                    <th>Linked Runner</th>
                    <th>Assignments</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.Volunteer.IsActive ? null : "table-light text-muted")">
                    <td>
                        @item.Volunteer.Name
                        @if (!item.Volunteer.IsActive) { <span class="badge bg-secondary ms-1">Inactive</span> }
                    </td>
                    <td>@item.Volunteer.Gender</td>
                    <td>@(item.Volunteer.IsClubMember ? "Yes" : "No")</td>
                    <td>@(item.Volunteer.IsFirstAidTrained ? "Yes" : "")</td>
                    <td>@(item.RunnerName ?? "")</td>
                    <td>@item.AssignmentCount</td>
                    <td class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Volunteer.Id">Edit</a>
                        <form method="post" asp-action="SetActive" asp-route-id="@item.Volunteer.Id" asp-route-isActive="@(!item.Volunteer.IsActive)">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-secondary" type="submit">
                                @(item.Volunteer.IsActive ? "Deactivate" : "Reactivate")
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
