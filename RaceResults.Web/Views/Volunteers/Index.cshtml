@model IReadOnlyList<RaceResults.Web.Models.VolunteerListItem>
@{
    ViewData["Title"] = "Volunteers";
    var showInactive = ViewBag.ShowInactive == true;
}

@{
    var unusedCount = Model.Count(i => i.AssignmentCount == 0);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Volunteers</h1>
    <div class="d-flex gap-2">
        @if (unusedCount > 0)
        {
            <form method="post" asp-action="DeleteAllUnused" asp-route-showInactive="@showInactive"
                  onsubmit="return confirm('Permanently delete @unusedCount volunteer(s) with no assignments? This cannot be undone.');">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger" type="submit">Delete @unusedCount unused</button>
            </form>
        }
        <a class="btn btn-primary" asp-action="Create">Add Volunteer</a>
    </div>
</div>

<p class="small text-muted">The volunteer register. Deactivate, never delete - past assignments stay counted in stats. London Marathon ballot entries (US29) count only for club members.</p>

@if (Model.Any())
{
    var active = Model.Count(i => i.Volunteer.IsActive);
    var members = Model.Count(i => i.Volunteer.IsActive && i.Volunteer.IsClubMember);
    var firstAid = Model.Count(i => i.Volunteer.IsActive && i.Volunteer.IsFirstAidTrained);
    <p class="small text-muted">
        <strong>@active active</strong> · @members member(s) · @firstAid first-aid trained · @(active - members) non-member(s)
    </p>
}

@if (TempData["FeedbackText"] is string feedback)
{
    var ftype = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@ftype" role="alert">@Html.Raw(feedback)</div>
}

<div class="mb-2">
    <a class="small" asp-action="Index" asp-route-showInactive="@(!showInactive)">@(showInactive ? "Hide inactive" : "Show inactive")</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No volunteers yet. Add the first one to start building a roster.</div>
}
else
{
    <div class="table-responsive" style="overflow-x: clip;">
        <table class="table table-striped align-middle">
            <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
                <tr>
                    <th>Name</th>
                    <th>Gender</th>
                    <th>Member</th>
                    <th>First Aid</th>
                    <th>Linked Runner</th>
                    <th>Assignments</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.Volunteer.IsActive ? null : "table-light text-muted")">
                    <td>
                        @item.Volunteer.Name
                        @if (!item.Volunteer.IsActive) { <span class="badge bg-secondary ms-1">Inactive</span> }
                    </td>
                    <td>@item.Volunteer.Gender</td>
                    <td>@(item.Volunteer.IsClubMember ? "Yes" : "No")</td>
                    <td>@(item.Volunteer.IsFirstAidTrained ? "Yes" : "")</td>
                    <td>@(item.RunnerName ?? "")</td>
                    <td>@item.AssignmentCount</td>
                    <td class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Volunteer.Id">Edit</a>
                        <form method="post" asp-action="SetActive" asp-route-id="@item.Volunteer.Id" asp-route-isActive="@(!item.Volunteer.IsActive)">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-secondary" type="submit">
                                @(item.Volunteer.IsActive ? "Deactivate" : "Reactivate")
                            </button>
                        </form>
                        @if (item.AssignmentCount == 0)
                        {
                            <form method="post" asp-action="Delete" asp-route-id="@item.Volunteer.Id" asp-route-showInactive="@showInactive"
                                  onsubmit="return confirm('Permanently delete @item.Volunteer.Name? This cannot be undone.');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
