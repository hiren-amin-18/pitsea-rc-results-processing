@model IReadOnlyList<RaceResults.Web.Models.VolunteerRole>
@using RaceResults.Web.Models
@{
    ViewData["Title"] = "Volunteer Roles";
    var eventType = (EventType)(ViewBag.EventType ?? EventType.CrownToCrown);
    var includeInactive = ViewBag.IncludeInactive == true;
    var allowListCounts = ViewBag.AllowListCounts as IDictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Volunteer Roles</h1>
    <a class="btn btn-primary" asp-action="Create" asp-route-eventType="@eventType">Add Role</a>
</div>

<p class="small text-muted">
    Role catalogue for @(eventType == EventType.CrownToCrown ? "Crown to Crown" : "Bluebell 5").
    Each role has a default and min/max count (override per-event). Restricted roles allow only specific volunteers; pre-placed roles
    pin a specific volunteer (the auto-allocator honours both).
</p>

@if (TempData["FeedbackText"] is string feedback)
{
    var ftype = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@ftype" role="alert">@Html.Raw(feedback)</div>
}

<div class="mb-2">
    <a class="small" asp-action="Index" asp-route-eventType="@eventType" asp-route-includeInactive="@(!includeInactive)">
        @(includeInactive ? "Hide retired" : "Show retired")
    </a>
</div>

<div class="table-responsive" style="overflow-x: clip;">
    <table class="table table-striped align-middle">
        <thead style="position: sticky; top: 0; z-index: 2; background-color: var(--bs-body-bg);">
            <tr>
                <th>Category</th>
                <th>Role</th>
                <th class="text-center">Default</th>
                <th class="text-center">Min / Max</th>
                <th class="text-center">Run after</th>
                <th>Flags</th>
                <th>Pre-placed</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var role in Model)
        {
            <tr class="@(role.IsActive ? null : "table-light text-muted")">
                <td>@role.Category</td>
                <td>
                    @role.Name
                    @if (!role.IsActive) { <span class="badge bg-secondary ms-1">Retired</span> }
                </td>
                <td class="text-center">@role.DefaultCount</td>
                <td class="text-center">@role.MinCount / @role.MaxCount</td>
                <td class="text-center">@role.RunAfterCapacity</td>
                <td>
                    @if (role.IsOptional) { <span class="badge bg-secondary me-1">Optional</span> }
                    @if (role.IsGenericPreference) { <span class="badge bg-info text-dark me-1">Generic preference</span> }
                    @if (role.RequiresFirstAid) { <span class="badge bg-danger me-1">First Aid</span> }
                    @if (role.HasEligibilityRestriction)
                    {
                        var allowed = allowListCounts.TryGetValue(role.Id, out var c) ? c : 0;
                        var label = allowed == 0 ? "Restricted (allow-list empty)" : $"Restricted ({allowed} allowed)";
                        var cls = allowed == 0 ? "bg-warning text-dark" : "bg-warning text-dark";
                        <span class="badge @cls me-1" title="Only people on the allow-list can be assigned to this role.">@label</span>
                    }
                </td>
                <td>@(role.PrePlacedVolunteer?.Name ?? "")</td>
                <td class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@role.Id">Edit</a>
                    <form method="post" asp-action="SetActive" asp-route-id="@role.Id" asp-route-isActive="@(!role.IsActive)" asp-route-eventType="@eventType">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-secondary" type="submit">@(role.IsActive ? "Retire" : "Reactivate")</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
