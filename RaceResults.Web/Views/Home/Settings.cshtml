@{
    ViewData["Title"] = "Settings";
}

<h1>Settings</h1>
<p class="text-muted">Personalize how the application looks on this device.</p>

<div class="card settings-card">
    <div class="card-body">
        <h5 class="card-title mb-3">Appearance</h5>
        <div class="form-check form-switch fs-5">
            <input class="form-check-input" type="checkbox" id="dark-mode-toggle" />
            <label class="form-check-label" for="dark-mode-toggle">Enable dark mode</label>
        </div>
        <p class="small text-muted mt-3 mb-0">This setting is stored in your browser and remembered for future visits.</p>
    </div>
</div>
