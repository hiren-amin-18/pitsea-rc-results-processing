@{
    var raceEvent = ViewBag.Event as RaceResults.Web.Models.RaceEvent;
    ViewData["Title"] = $"Generate Online Registration - {raceEvent?.EventName}";
}

<div class="mb-3">
    <h1>Generate Online Registration spreadsheet</h1>
    <p class="text-muted mb-0">
        @raceEvent?.EventName — @raceEvent?.EventDate.ToString("dd MMM yyyy")
    </p>
</div>

<div class="card">
    <div class="card-body">
        <p class="small text-muted">
            Upload the two CSV files exported from the online registration platform (adults 18+ and U18).
            You'll see a preview with any unresolved club names before the .xlsx is produced. Race number
            is left blank; you'll fill it in Excel and re-upload via <em>Race → Uploads</em>.
        </p>
        <form method="post" asp-action="Preview" asp-route-eventId="@raceEvent?.Id" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Adults CSV (18+)</label>
                    <input type="file" name="adults" accept=".csv" class="form-control" required />
                    <div class="form-text">The file <em>without</em> the <code>U18IsDependantOfUser</code> column.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">U18 CSV</label>
                    <input type="file" name="u18" accept=".csv" class="form-control" required />
                    <div class="form-text">The file <em>with</em> the <code>U18IsDependantOfUser</code> column.</div>
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" type="submit">Preview</button>
                <a class="btn btn-link" asp-controller="Events" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
