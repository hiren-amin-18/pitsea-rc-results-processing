@model RaceResults.Web.Models.EventsPageViewModel
@using RaceResults.Web.Models
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Events</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="GenerateSeason">Generate Season</a>
        <a class="btn btn-primary" asp-action="Create">Create Event</a>
    </div>
</div>

<p class="small text-muted">Deleting an event permanently removes its entrants, finish rows, and timing data. <a asp-controller="Home" asp-action="Settings">Download a backup</a> first.</p>

@if (TempData["FeedbackText"] is string feedback)
{
    var feedbackType = TempData["FeedbackType"] as string ?? "info";
    <div class="alert alert-@feedbackType" role="alert">@Html.Raw(feedback)</div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Type</th>
            <th>Current</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var raceEvent in Model.Events)
    {
        <tr class="@(raceEvent.IsArchived ? "table-light text-muted" : null)">
            <td>
                @raceEvent.EventName
                @if (raceEvent.IsArchived)
                {
                    <span class="badge bg-secondary ms-1">Archived</span>
                }
            </td>
            <td>
                @raceEvent.EventDate.ToString("dd MMM yyyy")
                @if (raceEvent.StartTime.HasValue)
                {
                    <span class="text-muted">@raceEvent.StartTime.Value.ToString(@"hh\:mm")</span>
                }
            </td>
            <td>@(raceEvent.EventType == EventType.CrownToCrown ? "Crown to Crown" : "Bluebell 5")</td>
            <td>@(raceEvent.Id == Model.CurrentEventId ? "Yes" : "No")</td>
            <td class="d-flex gap-2 flex-wrap">
                <a class="btn btn-sm btn-outline-info" asp-controller="VolunteerRoster" asp-action="Index" asp-route-eventId="@raceEvent.Id">Roster</a>
                @if (raceEvent.IsArchived)
                {
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Race" asp-action="Results" asp-route-eventId="@raceEvent.Id">View</a>
                    <form method="post" asp-action="Unarchive" asp-route-id="@raceEvent.Id" onsubmit="return confirm('Unarchive this event to allow changes again?');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-success" type="submit">Unarchive</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@raceEvent.Id">Edit</a>

                    @if (raceEvent.Id != Model.CurrentEventId)
                    {
                        <form method="post" asp-action="SetCurrent" asp-route-id="@raceEvent.Id">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Set Current</button>
                        </form>
                    }

                    <form method="post" asp-action="Archive" asp-route-id="@raceEvent.Id" onsubmit="return confirm('Archive this event? Its results become read-only. You can unarchive later.');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Archive</button>
                    </form>

                    <form method="post" asp-action="Delete" asp-route-id="@raceEvent.Id" onsubmit="return confirm('Delete this event and all associated results? This cannot be undone — consider downloading a backup from Settings first.');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                    </form>
                }

                @if (raceEvent.IsPublished)
                {
                    <form method="post" asp-action="Unpublish" asp-route-id="@raceEvent.Id">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-warning" type="submit">Unpublish</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-action="Publish" asp-route-id="@raceEvent.Id">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-success" type="submit">Publish</button>
                    </form>
                }
            </td>
        </tr>
        @if (raceEvent.IsPublished && !string.IsNullOrEmpty(raceEvent.PublicToken))
        {
            var publicUrl = Url.Action("Results", "Public", new { token = raceEvent.PublicToken }, Context.Request.Scheme);
            <tr class="table-light">
                <td colspan="5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">Public link</span>
                        <input type="text" class="form-control" value="@publicUrl" readonly onclick="this.select();" aria-label="Public results link" />
                        <a class="btn btn-outline-secondary" href="@publicUrl" target="_blank" rel="noopener">Open</a>
                    </div>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
