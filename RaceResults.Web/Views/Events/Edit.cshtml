@model RaceResults.Web.Models.EditEventInput
@using RaceResults.Web.Models
@{
    ViewData["Title"] = "Edit Event";
}

<h1>Edit Event</h1>

<form method="post" asp-action="Edit" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div class="col-md-6">
        <label asp-for="EventName" class="form-label"></label>
        <input asp-for="EventName" class="form-control" />
        <span asp-validation-for="EventName" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="EventDate" class="form-label"></label>
        <input asp-for="EventDate" class="form-control" type="date" />
        <span asp-validation-for="EventDate" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="EventType" class="form-label"></label>
        <select asp-for="EventType" class="form-select" asp-items="Html.GetEnumSelectList<EventType>()"></select>
        <span asp-validation-for="EventType" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
