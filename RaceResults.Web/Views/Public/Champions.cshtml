@model RaceResults.Web.Models.PublicChampionsViewModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Champions of Champions " + Model.SeasonYear;
}

<h2 class="h3">Champions of Champions - @Model.SeasonYear</h2>
<p class="mb-3"><a href="@Url.Action("Results", "Public", new { token = Model.Token })">← Back to @Model.EventName results</a></p>

@if (!Model.Leaderboard.Any())
{
    <div class="alert alert-info">No Champions of Champions data for this season yet.</div>
}
else
{
    foreach (var category in Model.Leaderboard.GroupBy(e => e.Category))
    {
        <h3 class="h5 mt-4">@category.Key</h3>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr><th style="width:70px;">Rank</th><th>Name</th><th>Club</th><th class="text-center">Events</th><th class="text-end">Points</th></tr>
                </thead>
                <tbody>
                @foreach (var entry in category.OrderBy(e => e.Rank))
                {
                    var bg = entry.Rank switch { 1 => "#ffd700", 2 => "#c0c0c0", 3 => "#cd7f32", _ => "" };
                    <tr style="@(string.IsNullOrEmpty(bg) ? "" : $"background-color:{bg};color:#000;")">
                        <td>@entry.Rank@(entry.IsPointsTied ? " †" : "")</td>
                        <td>@entry.Entrant.Name</td>
                        <td>@(string.IsNullOrWhiteSpace(entry.Entrant.Club) ? "Unaffiliated" : entry.Entrant.Club)</td>
                        <td class="text-center">@entry.RaceCount</td>
                        <td class="text-end fw-bold">@entry.TotalPoints</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    <p class="small text-muted mt-2">† tied on points and races completed.</p>
}
