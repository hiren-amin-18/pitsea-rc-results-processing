@using System.Text.RegularExpressions
@inject RaceResults.Web.Services.IRaceResultsService RaceResultsService
@{
    var currentEvent = RaceResultsService.GetCurrentEvent();

    var routeController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var routeAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool On(string controller, params string[] actions) =>
        string.Equals(routeController, controller, StringComparison.OrdinalIgnoreCase)
        && (actions.Length == 0 || actions.Any(a => string.Equals(routeAction, a, StringComparison.OrdinalIgnoreCase)));

    var onHome = On("Home", "Index");
    var onEvents = On("Events");
    var onRace = On("Race", "Uploads", "Results");
    var onStandings = On("Season", "Dashboard", "Runner", "Review", "ReviewPdf") || On("Champions") || On("CourseRecords");
    var onRunners = On("Runners");
    var onVolunteers = On("Volunteers") || On("VolunteerRoles") || On("VolunteerRoster");
    var onStats = On("Race", "Stats", "Top10") || On("VolunteerStats") || On("Season", "Stats");
    var onSettings = On("Home", "Settings");

    string Active(bool on) => on ? "active" : "";
    string Current(bool on) => on ? "page" : null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pitsea RC Race Result Processor</title>
    <script>
        (function () {
            var key = "rr-theme";
            var stored = localStorage.getItem(key);
            var theme = stored === "dark" || stored === "light"
                ? stored
                : (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" href="~/images/pitsea-logo-white.png" />
    <link rel="apple-touch-icon" href="~/images/pitsea-logo-white.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RaceResults.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img class="app-logo app-logo-light" src="~/images/pitsea-logo-white.png" alt="Pitsea Running Club logo" />
                    <img class="app-logo app-logo-dark" src="~/images/pitsea-logo-black.png" alt="Pitsea Running Club logo" />
                    <span>Pitsea RC Race Result Processor</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark @Active(onHome)" aria-current="@Current(onHome)" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark @Active(onEvents)" aria-current="@Current(onEvents)" asp-area="" asp-controller="Events" asp-action="Index">Events</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle @Active(onRace)" aria-current="@Current(onRace)" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Race</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Race" asp-action="Uploads">Uploads</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Race" asp-action="Results">Results</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle @Active(onStandings)" aria-current="@Current(onStandings)" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Standings</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Season" asp-action="Dashboard">Season</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Champions" asp-action="Leaderboard">Champions</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="CourseRecords" asp-action="Index">Records</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark @Active(onRunners)" aria-current="@Current(onRunners)" asp-area="" asp-controller="Runners" asp-action="Index">Runners</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle @Active(onVolunteers)" aria-current="@Current(onVolunteers)" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Volunteers</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Volunteers" asp-action="Index">Volunteers</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="VolunteerRoles" asp-action="Index">Roles</a></li>
                                @if (currentEvent is not null)
                                {
                                    <li><a class="dropdown-item" asp-area="" asp-controller="VolunteerRoster" asp-action="Index" asp-route-eventId="@currentEvent.Id">Roster</a></li>
                                }
                                else
                                {
                                    <li><span class="dropdown-item disabled" aria-disabled="true" title="Set a current event to manage its roster">Roster</span></li>
                                }
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle @Active(onStats)" aria-current="@Current(onStats)" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Stats</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Race" asp-action="Stats">Race Stats</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Season" asp-action="Stats">C2C Season Stats</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Race" asp-action="Top10">Top 10</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="VolunteerStats" asp-action="Index">Volunteer Stats</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark @Active(onSettings)" aria-current="@Current(onSettings)" asp-area="" asp-controller="Home" asp-action="Settings">Settings</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2 mt-2 mt-sm-0">
                        @if (currentEvent is not null)
                        {
                            <span class="small text-muted">Current: @currentEvent.EventName (@currentEvent.EventDate.ToString("dd MMM yyyy"))</span>
                        }
                        else
                        {
                            <span class="small text-muted">No current event</span>
                        }
                        <button id="theme-toggle-nav" class="btn btn-outline-secondary btn-sm" type="button" aria-label="Toggle dark mode">Dark mode</button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    @{
        var flashText = TempData["FeedbackText"] as string;
        var flashType = TempData["FeedbackType"] as string ?? "info";

        // A "large" flash (long text or several lines) is hard to read in a corner
        // toast, so render it as a dismissible inline alert at the top of the page.
        var flashPlain = flashText is null ? "" : Regex.Replace(flashText, "<[^>]+>", " ");
        var flashLineCount = flashText is null ? 0 : Regex.Matches(flashText, "<br", RegexOptions.IgnoreCase).Count + 1;
        var flashIsLarge = flashPlain.Length > 200 || flashLineCount >= 4;

        // Scale toast auto-dismiss to length so short "Saved" and longer messages
        // both get a fair reading window (5s–12s).
        var flashWords = flashPlain.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;
        var flashDelay = Math.Clamp(flashWords * 350, 5000, 12000);
    }
    <div class="container-xxl">
        <main role="main" class="pb-3">
            @if (flashText is not null && flashIsLarge)
            {
                <div class="alert alert-@flashType alert-dismissible fade show app-flash-alert app-flash-@flashType" role="alert">
                    <div>@Html.Raw(flashText)</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    @if (flashText is not null && !flashIsLarge)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090;">
            <div class="toast app-toast app-toast-@flashType" role="alert" aria-live="assertive" aria-atomic="true"
                 data-bs-delay="@flashDelay">
                <div class="d-flex">
                    <div class="toast-body">@Html.Raw(flashText)</div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <footer class="border-top footer text-muted">
        <div class="container-xxl">
            &copy; 2026 - Pitsea RC Race Result Processor
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
